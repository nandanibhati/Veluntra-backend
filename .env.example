# Copy this file to .env and fill in real values before running the server.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/Veluntra"

# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (web frontend dev + prod URLs).
# Native mobile apps are not subject to CORS, so this only affects browser clients.
CORS_ORIGINS="http://localhost:5173"

# JWT secrets — generate strong random strings for production,
# e.g. `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Local file uploads (product images, avatars) are served from this path.
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=5
