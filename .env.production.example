# Production environment template for docker-compose.prod.yml
#
# Copy this to `.env` next to docker-compose.prod.yml and fill in real values.
# Never commit the filled-in `.env` file — it belongs in your secret manager
# (or at minimum, in a git-ignored file on the deploy host only).

# --- Database ---
# Pick a real username/password — NOT the "Veluntra/Veluntra" development defaults.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=veluntra

# --- CORS ---
# Comma-separated list of the actual domain(s) your frontend is served from.
# e.g. https://www.example.com,https://example.com
CORS_ORIGINS=

# --- JWT secrets ---
# Generate two DIFFERENT random values (run this command twice):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=5
API_PORT=4000

# --- One-time bootstrap (used only by `node prisma/seed.production.js`, not by the app itself) ---
# Set these, run the bootstrap script once to create your first Super Admin login, then you
# can safely remove them from this file — SMTP, Cloudinary, and payment gateway credentials
# are configured afterwards from inside the admin panel (Settings), not via environment variables.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=
STORE_NAME=
STORE_CURRENCY=GBP
STORE_CURRENCY_SYMBOL=£
STORE_CONTACT_EMAIL=
